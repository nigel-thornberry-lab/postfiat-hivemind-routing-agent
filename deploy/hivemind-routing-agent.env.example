# Copy to /etc/postfiat/hivemind-routing-agent.env and restrict permissions:
# sudo install -m 600 -o postfiat -g postfiat deploy/hivemind-routing-agent.env.example /etc/postfiat/hivemind-routing-agent.env

# Required
PFT_TASKNODE_JWT=replace_with_live_jwt
PFT_TASKNODE_WSS_URL=wss://ws.testnet.postfiat.org

# Optional
PFT_TASKNODE_URL=https://tasknode.postfiat.org
PFT_TASKNODE_TIMEOUT_MS=30000
PFT_TASKNODE_WSS_TOPICS=task_created,task_updated
PFT_TASKNODE_DISPATCH_PATH=/api/routing/dispatch
PFT_DISPATCH_DRY_RUN=false
PFT_DISPATCH_MAX_ATTEMPTS=3
PFT_ROUTING_EVENT_OUTPUT=data/latest-match-result.json
PFT_E2E_DRY_RUN_LOG=data/e2e-dry-run-log.json
PFT_ROUTING_HEALTH_PORT=8787
